[Unit]
Description=uSipipo Backend API Service
Documentation=https://github.com/uSipipo-Team/usipipo-backend
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=notify
User=usipipo
Group=usipipo
WorkingDirectory=/home/usipipo/usipipo-backend

# Environment
Environment="PATH=/home/usipipo/usipipo-backend/.venv/bin"
EnvironmentFile=-/home/usipipo/usipipo-backend/.env

# Execution - Uses API_HOST and API_PORT from .env
ExecStart=/home/usipipo/usipipo-backend/.venv/bin/uvicorn src.main:app --host ${API_HOST:-0.0.0.0} --port ${API_PORT:-8000} --workers 4
ExecReload=/bin/kill -s HUP $MAINPID
KillMode=mixed
KillSignal=SIGTERM
TimeoutStopSec=30

# Restart policy
Restart=always
RestartSec=10
StartLimitBurst=3
StartLimitIntervalSec=60

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/home/usipipo/usipipo-backend/logs /home/usipipo/usipipo-backend/temp /home/usipipo/usipipo-backend/static

# Resource limits
LimitNOFILE=65535
Nice=-5

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=usipipo-backend

[Install]
WantedBy=multi-user.target
