# =============================================================================
# uSipipo Backend - Production Environment Configuration
# =============================================================================
# Copy this file to .env in production server
# Configure all REQUIRED values before starting the service
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_ENV=production
PROJECT_NAME=uSipipo Backend
DEFAULT_LANG=es

# =============================================================================
# SECURITY CONFIGURATION (REQUIRED)
# =============================================================================
# Generate with: openssl rand -hex 32 (minimum 32 bytes for security)
SECRET_KEY=YOUR_SECRET_KEY_GENERATED_WITH_OPENSSL
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# TELEGRAM BOT CONFIGURATION (REQUIRED)
# =============================================================================
# Get TOKEN from @BotFather in Telegram
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
ADMIN_ID=YOUR_TELEGRAM_USER_ID
AUTHORIZED_USERS=[YOUR_TELEGRAM_USER_ID]
BOT_USERNAME=usipipo_bot
TELEGRAM_RATE_LIMIT=30

# =============================================================================
# SERVER CONFIGURATION (REQUIRED)
# =============================================================================
# Public server IP address
SERVER_IP=YOUR_SERVER_PUBLIC_IP
SERVER_IPV4=YOUR_SERVER_PUBLIC_IP

# =============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# =============================================================================
# PostgreSQL connection URL
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://usipipo:YOUR_DB_PASSWORD@localhost:5432/usipipo
DB_POOL_SIZE=10
DB_TIMEOUT=30

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT=60
CORS_ORIGINS=["https://usipipo.duckdns.org"]

# =============================================================================
# MINI APP CONFIGURATION
# =============================================================================
MINIAPP_ENABLED=true
MINIAPP_URL=https://usipipo.duckdns.org

# =============================================================================
# WIREGUARD VPN CONFIGURATION
# =============================================================================
WG_INTERFACE=wg0
WG_SERVER_PORT=64465
WG_SERVER_PUBKEY=YOUR_WIREGUARD_SERVER_PUBLIC_KEY
WG_SERVER_PRIVKEY=YOUR_WIREGUARD_SERVER_PRIVATE_KEY
WG_PATH=/etc/wireguard
WG_ENDPOINT=YOUR_SERVER_PUBLIC_IP:WG_PORT
WG_CLIENT_DNS_1=1.1.1.1

# =============================================================================
# OUTLINE VPN CONFIGURATION
# =============================================================================
# Format: https://ip:port/api_key
OUTLINE_API_URL=https://YOUR_SERVER_IP:OUTLINE_PORT/OUTLINE_API_KEY

# =============================================================================
# VPN KEY LIMITS
# =============================================================================
VPN_KEY_EXPIRE_DAYS=30
MAX_KEYS_PER_USER=5

# =============================================================================
# PLAN CONFIGURATION
# =============================================================================
FREE_PLAN_MAX_KEYS=2
FREE_PLAN_DATA_LIMIT_GB=10
VIP_PLAN_MAX_KEYS=10
VIP_PLAN_DATA_LIMIT_GB=50
VIP_PLAN_COST_STARS=10
BILLING_CYCLE_DAYS=30
KEY_CLEANUP_DAYS=90
REFERRAL_COMMISSION_PERCENT=10

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/backend.log
ENABLE_METRICS=false

# =============================================================================
# AUTO MEMORY CLEANUP (RAM)
# =============================================================================
MEMORY_CLEANUP_ENABLED=true
MEMORY_CLEANUP_THRESHOLD_PERCENT=80
MEMORY_CLEANUP_CRITICAL_PERCENT=90
MEMORY_CLEANUP_INTERVAL_MINUTES=10
MEMORY_NOTIFY_ADMIN=true

# =============================================================================
# PATHS & DIRECTORIES
# =============================================================================
TEMP_PATH=./temp
QR_CODE_PATH=./static/qr_codes
CLIENT_CONFIGS_PATH=./static/configs

# =============================================================================
# TRON DEALER API (Crypto Payments) - REQUIRED
# =============================================================================
TRON_DEALER_API_KEY=YOUR_TRON_DEALER_API_KEY
TRON_DEALER_WEBHOOK_SECRET=GENERATED_WEBHOOK_SECRET
TRON_DEALER_SWEEP_WALLET=YOUR_BSC_WALLET_ADDRESS

# =============================================================================
# DYNAMIC DNS (DuckDNS) - REQUIRED
# =============================================================================
DUCKDNS_DOMAIN=usipipo
DUCKDNS_TOKEN=YOUR_DUCKDNS_TOKEN
PUBLIC_URL=https://usipipo.duckdns.org
