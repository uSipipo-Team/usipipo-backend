# uSipipo Backend - Production Environment Configuration
# Copy this file to .env in production server

# Application
APP_ENV=production
APP_DEBUG=false
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://usipipo:YOUR_SECURE_PASSWORD@localhost:5432/usipipo
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# JWT Authentication (generate with: openssl rand -hex 32)
JWT_SECRET=YOUR_SUPER_SECRET_JWT_KEY_MIN_32_BYTES
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# TronDealer API (for BSC wallet management)
TRONDEALER_API_KEY=your-trondealer-api-key
TRONDEALER_API_URL=https://api.trondealer.com

# Telegram Bot (for Stars payments)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_STARS_ENABLED=true

# VPN Providers
WIREGUARD_SERVER_IP=your.wireguard.server.ip
WIREGUARD_API_URL=http://localhost:8080
OUTLINE_API_URL=https://your-outline-server.com/api

# Logging
LOG_LEVEL=INFO
LOG_FILE=/home/usipipo/usipipo-backend/logs/backend.log

# CORS (comma-separated origins)
CORS_ORIGINS=https://usipipo.duckdns.org

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
