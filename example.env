# Security
JWT_SECRET=your-super-secret-key-must-be-at-least-32-bytes-long-for-security
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Telegram
TELEGRAM_TOKEN=your-telegram-bot-token

# Database
DATABASE_URL=postgresql+asyncpg://usipipo:pass@localhost:5432/usipipo

# Redis
REDIS_URL=redis://localhost:6379

# Application
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
